# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI (server-side keys — never expose to client)
GEMINI_API_KEY=
CLAUDE_API_KEY=

# AI status flags (set to "true" to show as connected in settings page)
NEXT_PUBLIC_CLAUDE_CONFIGURED=
NEXT_PUBLIC_GEMINI_CONFIGURED=

# Upstash Redis (rate limiting — optional, falls back to in-memory for dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Playwright Auth (optional — authenticated tests skip if unset)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
