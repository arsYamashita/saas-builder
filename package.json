{
  "name": "saas-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:auth": "playwright test --project=logged-in",
    "test:e2e:all": "playwright test",
    "test:ui": "playwright test --ui",
    "test:cleanup": "tsx scripts/cleanup-e2e-data.ts",
    "regression": "tsx scripts/run-template-regression.ts",
    "regression:all": "tsx scripts/run-template-regression.ts --all-green",
    "regression:mca": "tsx scripts/run-template-regression.ts --template membership_content_affiliate",
    "regression:rsv": "tsx scripts/run-template-regression.ts --template reservation_saas",
    "regression:crm": "tsx scripts/run-template-regression.ts --template simple_crm_saas",
    "regression:cms": "tsx scripts/run-template-regression.ts --template community_membership_saas",
    "regression:iao": "tsx scripts/run-template-regression.ts --template internal_admin_ops_saas",
    "regression:nightly": "bash scripts/run-nightly-regression.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "@hookform/resolvers": "^3.9.0",
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "next": "14.2.0",
    "pg": "^8.20.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.52.0",
    "stripe": "^16.0.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
